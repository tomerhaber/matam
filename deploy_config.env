REM ===================================================================
REM  Optional configuration for install_server.cmd and start_pocketbase.cmd
REM  Edit BEFORE running install_server.cmd to customize.
REM  Format:  KEY=value  (no spaces around =, no quotes)
REM ===================================================================

REM  Bind address. 0.0.0.0 = accept from any network interface.
REM  Use 127.0.0.1 to restrict to localhost only.
BIND=0.0.0.0:8090

REM  Master password used for BOTH:
REM    - The PocketBase superuser (http://server:8090/_/  - the DB admin console)
REM    - The MATAM app's first manager account (admin@matam.local)
REM  You should change this in production - anyone who knows it has full control.
ADMIN_EMAIL=admin@matam.local
ADMIN_PASSWORD=matam2026

REM  Create the initial admin user on first install:
REM    yes  (default)  - auto-create admin@matam.local as a manager
REM                      so you can log into the app right after install
REM    no             - only the PocketBase superuser is created;
REM                      you'll add the first manager yourself via the admin UI
CREATE_INITIAL_USER=yes
